DATABASE_URL=postgresql+asyncpg://root:root@tbc_postgresql_db:5432/upmovies
TEST_DATABASE_URL=postgresql+asyncpg://root:root@tbc_postgresql_db:5432/upmovies_test
ADMIN_TOKEN=dev-secret-change-me
TMDB_API_KEY=dev-tmdb-key
ANTHROPIC_API_KEY=
# Optional: enable Sentry error reporting. Leave unset to disable (default in local dev).
# Use the backlotter-backend project DSN from Sentry (org neuroticsasquatch).
# SENTRY_DSN=
# Optional: healthchecks.io deadman ping URLs for the Coolify scheduled tasks that run
# `python -m upmovies.pipeline_run daily|hourly`. Leave unset in local dev (ping no-ops).
# HEALTHCHECK_DAILY_URL=
# HEALTHCHECK_HOURLY_URL=
